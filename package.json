{
	"name": "make-mp-data",
	"version": "3.0.3",
	"description": "builds all mixpanel primitives for a given project",
	"type": "module",
	"main": "index.js",
	"types": "types.d.ts",
	"files": [
		"index.js",
		"entry.js",
		"types.d.ts",
		"lib/",
		"dungeons/",
		"!dungeons/customers/",
		"package.json",
		"README.md"
	],
	"scripts": {
		"post": "npm publish",
		"test": "NODE_ENV=test vitest run",
		"test:coverage": "NODE_ENV=test vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"dev": "nodemon scratch.mjs --ignore ./data/*",
		"prune": "rm -f ./data/* && rm -f ./tmp/* && rm -f vscode-profile-*",
		"deps": "./scripts/update-deps.sh",
		"dungeon:run": "node ./scripts/run-dungeon.mjs",
		"dungeon:to-json": "node ./scripts/dungeon-to-json.mjs",
		"dungeon:from-json": "node ./scripts/json-to-dungeon.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ak--47/make-mp-data.git"
	},
	"bin": {
		"make-mp-data": "./entry.js"
	},
	"keywords": [
		"mixpanel",
		"stream",
		"analytics",
		"tracking",
		"server",
		"CLI",
		"datamart",
		"scd 2",
		"dummy data",
		"fake data"
	],
	"author": "ak@mixpanel.com",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/ak--47/make-mp-data/issues"
	},
	"homepage": "https://github.com/ak--47/make-mp-data#readme",
	"dependencies": {
		"@google-cloud/storage": "^7.14.0",
		"ak-tools": "^1.1.12",
		"chance": "^1.1.11",
		"dayjs": "^1.11.11",
		"dotenv": "^16.4.5",
		"hyparquet-writer": "^0.6.1",
		"mixpanel": "^0.18.0",
		"mixpanel-import": "^3.2.8",
		"p-limit": "^3.1.0",
		"pino": "^9.0.0",
		"pino-pretty": "^11.0.0",
		"seedrandom": "^3.0.5",
		"sentiment": "^5.0.2",
		"tracery-grammar": "^2.8.4",
		"yargs": "^17.7.2"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^2.1.9",
		"@vitest/ui": "^2.1.9",
		"nodemon": "^3.1.3",
		"typescript": "^5.6.0",
		"vitest": "^2.1.9"
	},
	"nodemonConfig": {
		"ignore": [
			"data/",
			"tmp/"
		]
	}
}
